# ─── Wereact Website Factory — API keys ───
# Copy this file to ".env" and fill in your keys, then:  source .env
# (or the factory will read .env automatically via the Asset Engine)

# Asset Engine — image generation backups (fallback order below)
# 1) Google Gemini "Nano Banana" (Gemini 2.5 Flash Image) — primary backup
#    Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 2) FLUX via fal.ai — photoreal heroes
#    Get a key: https://fal.ai/dashboard/keys
FAL_KEY=

# 3) FLUX via Together AI — last-resort free schnell
#    Get a key: https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# higgsfield is used via its MCP connection (no key needed here).

# ─── Optional: SEO Google integrations (claude-seo /seo google) ───
# Google PageSpeed Insights API key (for Core Web Vitals lab data)
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=
